{
  "expo": {
    "name": "TradeMind AI",
    "slug": "trademind-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "trademind-ai",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#131722"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#080C14"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "TradeMind AI uses your photo library to analyze chart screenshots.",
          "cameraPermission": "TradeMind AI uses your camera to capture live chart images for AI analysis."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
